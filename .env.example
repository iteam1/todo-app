# =============================================================================
# Claude Code Hook Configuration
# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit your actual .env file.
# =============================================================================

# Task review hook (Stop hook in .claude/scripts/task-review.sh)
# Controls whether Claude pauses after each response for user review.
#   on  → enabled (default): Claude stops after changes, waits for "ok" or feedback
#   off → disabled: Claude runs freely without pausing for review
SPECKIT_REVIEW_HOOK=on
